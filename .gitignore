# ==========================================
#   USB Karaoke App — .gitignore
#   Stack: Electron + React + Vite + Node.js
# ==========================================

# --- Dependencies ---
node_modules/
.pnp
.pnp.js

# --- Build Outputs ---
dist/
dist-electron/
build/
out/
release/

# --- Vite ---
*.local
.vite/

# --- Electron Builder ---
# Packaged app output (portable .exe, etc.)
/app/
*.exe
*.dmg
*.AppImage
*.deb
*.rpm
*.snap
*.pkg
*.zip
*.tar.gz

# --- Environment & Secrets ---
.env
.env.local
.env.development
.env.production
.env.*.local

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- OS Files ---
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# --- Editor & IDE ---
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- SQLite Database (runtime file, not source) ---
*.sqlite
*.sqlite3
*.db

# --- Song Media Files (too large for git) ---
songs/
*.mp4
*.mp3
*.cdg
*.lrc

# --- Auto-generated Song Index (regenerated by scan script) ---
songs.json

# --- Electron Cache ---
.electron/
electron-packager/

# --- TypeScript ---
*.tsbuildinfo

# --- Test Coverage ---
coverage/
.nyc_output/

# --- Misc ---
*.pem
.cache/
tmp/
temp/